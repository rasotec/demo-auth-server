<h1>Enable 2FA</h1>

<p style="color:#A4A4A4; margin-bottom:1.5rem; font-size:0.95rem;">
  Scan the QR code with Google Authenticator or any TOTP app, then enter the code to confirm.
</p>

{{#if error}}
  <div class="alert alert-error">{{error}}</div>
{{/if}}

<div style="text-align:center; margin-bottom:1.5rem;">
  <img src="{{qrCode}}" alt="QR Code" style="width:180px; height:180px; border-radius:5px;">
</div>

<details style="margin-bottom:1.5rem;">
  <summary style="cursor:pointer; color:var(--akzent1); font-size:0.875rem; font-weight:600;">
    Can't scan? Enter key manually
  </summary>
  <code style="display:block; margin-top:0.75rem; padding:0.6rem 0.75rem; background:var(--darkestblue); border:0.2rem solid var(--akzent1); border-radius:5px; font-size:0.8rem; word-break:break-all; color:#fff;">{{secret}}</code>
</details>

<form method="POST" action="/2fa/setup">
  <label for="token">Verification code</label>
  <input type="text" id="token" name="token" required autocomplete="one-time-code"
    inputmode="numeric" maxlength="6" placeholder="000000" autofocus>
  <button type="submit">Verify &amp; Enable</button>
</form>

<div class="link"><a href="/dashboard">Cancel</a></div>
